cabal-version:      3.4
name:               UmbraVox
version:            0.7.0
synopsis:           Decentralized encrypted communications protocol
description:
  UmbraVox is a research-oriented encrypted messaging project with
  post-quantum cryptography, preserved blockchain-facing design work,
  and a Haskell-first runtime backed by handwritten F* formal models.
  The current assurance boundary and trust gaps are documented in
  README.md and doc/assurance-matrix.md.
license:            Apache-2.0
license-file:       LICENSE
build-type:         Simple

flag pure-haskell
  description: Use pure Haskell reference implementations (no FFI C)
  default:     True
  manual:      True

flag pure-haskell-crypto
  description: Use pure Haskell crypto (NOT constant-time). Disable for FFI to C.
  default:     False
  manual:      True

flag profiling
  description: Enable GHC cost-centre profiling annotations
  default:     False
  manual:      True

flag coverage
  description: Enable HPC instrumentation for MC/DC coverage
  default:     False
  manual:      True

flag chaste-build
  description: Compile an ephemeral-only client with persistence/discovery features removed from the runtime surface
  default:     False
  manual:      True

flag wasm
  description: Build only pure crypto core (no network/TUI/storage). For use with wasm32-wasi-ghc via ghc-wasm-meta.
  default:     False
  manual:      True



common warnings
  ghc-options:
    -Wall
    -Wcompat
    -Widentities
    -Wincomplete-record-updates
    -Wincomplete-uni-patterns
    -Wmissing-deriving-strategies
    -Wpartial-fields
    -Wredundant-constraints
    -Wunused-packages

common lang
  default-language:   Haskell2010
  default-extensions:
    BangPatterns
    DeriveGeneric
    DerivingStrategies
    GeneralizedNewtypeDeriving
    LambdaCase
    OverloadedStrings
    ScopedTypeVariables
    StrictData
    TypeApplications

library
  import:           warnings, lang
  hs-source-dirs:   src
  -- Modules included unconditionally: pure crypto core, safe for WASM target.
  -- See doc/WASM-TARGET.md and the 'wasm' flag below.
  exposed-modules:
    -- Crypto primitives (pure; WASM-eligible)
    UmbraVox.Crypto.SecureBytes
