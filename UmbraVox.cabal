cabal-version:      3.0
name:               UmbraVox
version:            0.1.0.0
synopsis:           Decentralized encrypted communications protocol
description:
  UmbraVox is a research-oriented encrypted messaging project with
  post-quantum cryptography, preserved blockchain-facing design work,
  and a Haskell-first runtime backed by handwritten F* formal models.
  The current assurance boundary and trust gaps are documented in
  README.md and doc/assurance-matrix.md.
license:            Apache-2.0
license-file:       LICENSE
build-type:         Simple

flag pure-haskell
  description: Use pure Haskell reference implementations (no FFI C)
  default:     True
  manual:      True

flag profiling
  description: Enable GHC cost-centre profiling annotations
  default:     False
  manual:      True

flag coverage
  description: Enable HPC instrumentation for MC/DC coverage
  default:     False
  manual:      True

common warnings
  ghc-options:
    -Wall
    -Wcompat
    -Widentities
    -Wincomplete-record-updates
    -Wincomplete-uni-patterns
    -Wmissing-deriving-strategies
    -Wpartial-fields
    -Wredundant-constraints
    -Wunused-packages

common lang
  default-language:   Haskell2010
  default-extensions:
    BangPatterns
    DeriveGeneric
    DerivingStrategies
    GeneralizedNewtypeDeriving
    LambdaCase
    OverloadedStrings
    ScopedTypeVariables
    StrictData
    TypeApplications

library
  import:           warnings, lang
  hs-source-dirs:   src
  exposed-modules:
    -- Crypto primitives
    UmbraVox.Crypto.SHA256
    UmbraVox.Crypto.SHA512
    UmbraVox.Crypto.HMAC
    UmbraVox.Crypto.HKDF
    UmbraVox.Crypto.AES
    UmbraVox.Crypto.GCM
    UmbraVox.Crypto.Curve25519
    UmbraVox.Crypto.Ed25519
    UmbraVox.Crypto.Keccak
    UmbraVox.Crypto.Poly1305
    UmbraVox.Crypto.MLKEM
    UmbraVox.Crypto.VRF
    UmbraVox.Crypto.Random
    UmbraVox.Crypto.ConstantTime
    UmbraVox.Crypto.StealthAddress
    UmbraVox.Crypto.BIP39
    UmbraVox.Crypto.Export
    -- Signal protocol
    UmbraVox.Crypto.Signal.X3DH
    UmbraVox.Crypto.Signal.PQXDH
    UmbraVox.Crypto.Signal.DoubleRatchet
    UmbraVox.Crypto.Signal.SenderKeys
    UmbraVox.Crypto.Signal.Session
    UmbraVox.Crypto.PQWrapper
    UmbraVox.Crypto.KeyStore
    -- Active generated coverage spans the preserved Haskell, C, and FFI
    -- namespaces. Generated C and FFI paths are linked through truthful
    -- bridge wrappers plus compile/link probes.
    UmbraVox.Crypto.Generated.AES256
    UmbraVox.Crypto.Generated.ChaCha20
    UmbraVox.Crypto.Generated.HKDF
    UmbraVox.Crypto.Generated.HMAC
    UmbraVox.Crypto.Generated.Keccak
    UmbraVox.Crypto.Generated.MLKEM768
    UmbraVox.Crypto.Generated.Poly1305
    UmbraVox.Crypto.Generated.SHA256
    UmbraVox.Crypto.Generated.SHA512
    UmbraVox.Crypto.Generated.X25519
    UmbraVox.Crypto.Generated.FFI.AES256
    UmbraVox.Crypto.Generated.FFI.ChaCha20
    UmbraVox.Crypto.Generated.FFI.HKDF
    UmbraVox.Crypto.Generated.FFI.HMAC
    UmbraVox.Crypto.Generated.FFI.Keccak
    UmbraVox.Crypto.Generated.FFI.MLKEM768
    UmbraVox.Crypto.Generated.FFI.Poly1305
    UmbraVox.Crypto.Generated.FFI.SHA256
    UmbraVox.Crypto.Generated.FFI.SHA512
    UmbraVox.Crypto.Generated.FFI.X25519
    -- Consensus
    UmbraVox.Consensus.Types
    UmbraVox.Consensus.Block
    UmbraVox.Consensus.Ledger
    UmbraVox.Consensus.Protocol
    UmbraVox.Consensus.LeaderElection
    UmbraVox.Consensus.Validation
    UmbraVox.Consensus.ForkChoice
    UmbraVox.Consensus.Nonce
    UmbraVox.Consensus.Truncation
    UmbraVox.Consensus.Mempool
    -- Economics
    UmbraVox.Economics.Token
    UmbraVox.Economics.Fees
    UmbraVox.Economics.Rewards
    UmbraVox.Economics.Penalty
