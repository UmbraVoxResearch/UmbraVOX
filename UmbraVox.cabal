    UmbraVox.TUI.Types
    UmbraVox.TUI.Constants
    UmbraVox.TUI.Text
    UmbraVox.TUI.PaginatedList
    UmbraVox.TUI.Terminal
    UmbraVox.TUI.Layout
    UmbraVox.TUI.Dialog
    UmbraVox.TUI.Menu
    UmbraVox.TUI.RuntimeCommand
    UmbraVox.TUI.RuntimeEvent
    UmbraVox.TUI.RuntimeNetwork
    UmbraVox.TUI.RuntimeSettings
    UmbraVox.TUI.Render
    UmbraVox.TUI.Input
    UmbraVox.TUI.Actions
    UmbraVox.TUI.Actions.Session
    UmbraVox.TUI.Actions.Export
    UmbraVox.TUI.Handshake
    -- Version
    UmbraVox.Version
    -- Tools
    UmbraVox.Tools.Complexity
    UmbraVox.Tools.FStarVerify
    UmbraVox.Tools.FetchReferences
  build-depends:
    base         >= 4.18  && < 5,
    bytestring   >= 0.11  && < 0.13,
    containers   >= 0.6   && < 0.8,
    array        >= 0.5   && < 0.6,
    stm          >= 2.5   && < 2.6,
    network      >= 3.1   && < 3.3,
    binary       >= 0.8   && < 0.9,
    directory    >= 1.3   && < 1.4,
    filepath     >= 1.4   && < 1.6,
    time         >= 1.12  && < 1.15,
    process      >= 1.6   && < 1.7,
    text         >= 2.0   && < 2.2,
    unix         >= 2.8   && < 2.9
  c-sources:
    csrc/generated/aes256.c
    csrc/generated/chacha20.c
    csrc/generated/hkdf.c
    csrc/generated/hmac.c
    csrc/generated/keccak.c
    csrc/generated/mlkem768.c
    csrc/generated/poly1305.c
    csrc/generated/sha256.c
    csrc/generated/sha512.c
    csrc/generated/x25519.c

executable umbravox
  import:           warnings, lang
  main-is:          Main.hs
  hs-source-dirs:   app
  build-depends:
    base         >= 4.18  && < 5,
    bytestring   >= 0.11  && < 0.13,
    containers   >= 0.6   && < 0.8,
    directory    >= 1.3   && < 1.4,
    filepath     >= 1.4   && < 1.6,
    network      >= 3.1   && < 3.3,
    unix         >= 2.8   && < 2.9,
    UmbraVox
  ghc-options:      -threaded -rtsopts "-with-rtsopts=-N"

executable codegen
  import:           warnings, lang
  main-is:          Main.hs
  hs-source-dirs:   codegen
  other-modules:
    CryptoGen
    CBORGen
    FSMGen
    TestGen
  build-depends:
    base         >= 4.18  && < 5,
    bytestring   >= 0.11  && < 0.13,
    containers   >= 0.6   && < 0.8,
    directory    >= 1.3   && < 1.4,
    filepath     >= 1.4   && < 1.6

executable check-complexity
  import:           warnings, lang
  main-is:          Main.hs
  hs-source-dirs:   scripts/check-complexity
  build-depends:
    base         >= 4.18  && < 5,
    UmbraVox
  ghc-options:      -threaded

executable fstar-verify
  import:           warnings, lang
  main-is:          Main.hs
  hs-source-dirs:   scripts/fstar-verify
  build-depends:
    base         >= 4.18  && < 5,
    UmbraVox
  ghc-options:      -threaded

executable fetch-references
  import:           warnings, lang
  main-is:          Main.hs
  hs-source-dirs:   scripts/fetch-references
  build-depends:
    base         >= 4.18  && < 5,
    directory    >= 1.3   && < 1.4,
    UmbraVox
  ghc-options:      -threaded

