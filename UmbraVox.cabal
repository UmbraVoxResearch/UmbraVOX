      csrc/secure_mlock.c
      csrc/sqlite3_shim.c
      csrc/generated/aes256.c
      -- M38.2: EverCrypt AES-256-GCM + ChaCha20-Poly1305 SIMD (INTERIM PRODUCTION)
      -- EverCrypt AEAD dispatch layer
      csrc/hacl/EverCrypt_AEAD.c
      csrc/hacl/EverCrypt_AutoConfig2.c
      csrc/hacl/EverCrypt_Chacha20Poly1305.c
      csrc/hacl/EverCrypt_Cipher.c
      csrc/hacl/Vale.c
      csrc/hacl/Lib_Memzero0.c
      csrc/hacl/hacl_fsmath.c
      -- ChaCha20-Poly1305 AEAD: scalar + SIMD128 + SIMD256
      csrc/hacl/Hacl_AEAD_Chacha20Poly1305.c
      csrc/hacl/Hacl_AEAD_Chacha20Poly1305_Simd128.c
      csrc/hacl/Hacl_AEAD_Chacha20Poly1305_Simd256.c
      csrc/hacl/Hacl_Chacha20_Vec128.c
      csrc/hacl/Hacl_Chacha20_Vec256.c
      csrc/hacl/Hacl_MAC_Poly1305_Simd128.c
      csrc/hacl/Hacl_MAC_Poly1305_Simd256.c
      -- AES-256-GCM bridge
      csrc/hacl/bridge_aesgcm.c
      -- ChaCha20-Poly1305 AEAD bridge (wraps EverCrypt_Chacha20Poly1305, pure-software)
      csrc/hacl/bridge_chacha20poly1305.c
      csrc/hacl/Hacl_Chacha20.c
      csrc/hacl/bridge_chacha20.c
      -- M13.15.14: HACL* verified HKDF (replaces generated/hkdf.c as primary impl)
      -- generated/hkdf.c is RETAINED in csrc/ as differential testing oracle.
      csrc/hacl/Hacl_HKDF.c
      csrc/hacl/bridge_hkdf.c
      -- M13.15.13: HACL* verified HMAC (replaces generated/hmac.c as primary impl)
      -- generated/hmac.c is RETAINED in csrc/ as differential testing oracle.
      csrc/hacl/Hacl_Hash_Blake2b.c
      csrc/hacl/Hacl_Hash_Blake2s.c
      csrc/hacl/Hacl_Hash_MD5.c
      csrc/hacl/Hacl_Hash_SHA1.c
      csrc/hacl/Hacl_HMAC.c
      csrc/hacl/bridge_hmac.c
      -- M13.15.12: HACL* verified Keccak/SHA-3 (replaces generated/keccak.c as primary impl)
      -- generated/keccak.c is RETAINED in csrc/ as differential testing oracle.
      csrc/hacl/Hacl_Hash_SHA3.c
      csrc/hacl/bridge_keccak.c
      csrc/generated/mlkem768.c
      csrc/hacl/Hacl_MAC_Poly1305.c
      csrc/hacl/bridge_poly1305.c
      -- M13.15.8/9: HACL* verified SHA-256 and SHA-512 via upstream Hacl_Hash_SHA2.
      -- generated/sha256.c and generated/sha512.c are RETAINED as differential testing oracles.
      -- hacl_sha256_portable.c / hacl_sha512_portable.c are retained for differential testing only.
      csrc/hacl/Hacl_Hash_SHA2.c
      csrc/hacl/bridge_sha256.c
      csrc/hacl/bridge_sha512.c
      csrc/generated/x25519.c
      csrc/generated/vrf.c
      csrc/generated/pqwrapper.c
      csrc/generated/messageformat.c
      csrc/generated/wireformat.c
      csrc/generated/ed25519extended.c
      csrc/generated/dandelion.c
      csrc/generated/networkprotocol.c
      csrc/generated/sessionstate.c
      csrc/constant_time.c
      -- M40.33: platform-aware OS entropy source (getrandom/getentropy/BCrypt).
      -- Replaces raw /dev/urandom reads in Crypto.Random; csrc/generated/entropy.c
      -- is a documented non-oracle stub and is intentionally NOT compiled.
      csrc/entropy/bridge_entropy.c
      -- M13.15.4 / M13.15.5: fiat-crypto GF(2^255-19) field ops + Ed25519/X25519 bridges
      csrc/fiat/fiat_25519_64.c
      csrc/fiat/bridge_ed25519.c
      csrc/fiat/bridge_x25519.c
    include-dirs:
      csrc
      csrc/hacl
      csrc/hacl/krml
      csrc/hacl/krml/internal
      csrc/fiat
      csrc/entropy
      csrc/extracted
    -- M40.33: -std=gnu11 (was c99) so csrc/entropy/bridge_entropy.c can use
    -- C11 <stdatomic.h> for the pthread_atfork flag. gnu11 is a backward-
    -- compatible superset of gnu99 and retains the GNU extensions HACL* uses.
    cc-options: -std=gnu11 -D_DEFAULT_SOURCE=1 -D_ISOC11_SOURCE=1 -fstack-protector-strong -D_FORTIFY_SOURCE=2 -Wformat -Wformat-security
      -DFIAT_VENDORED -Wno-unused-function -Wno-unused-parameter
  -- M38.2: Vale assembly (AES-NI + GHASH) — x86-64 only
  if !flag(wasm) && !os(windows) && arch(x86_64) && os(linux)
    asm-sources:
      csrc/hacl/aesgcm-x86_64-linux.S
      csrc/hacl/cpuid-x86_64-linux.S
  if !flag(wasm) && !os(windows) && arch(x86_64) && os(darwin)
    asm-sources:
      csrc/hacl/aesgcm-x86_64-darwin.S
  -- M38.2: SIMD intrinsic flags required by EverCrypt SIMD ChaCha20-Poly1305
  if !flag(wasm) && !os(windows) && arch(x86_64)
    cc-options: -maes -mpclmul -msse4.2 -mavx -mavx2
  -- M40.33d: Windows entropy bridge (BCryptGenRandom). Only the entropy
  -- primitive is wired for Windows today; the remaining C crypto bridges are
  -- POSIX-only (see the !os(windows) block above), so a full Windows build is
  -- not yet supported. This stanza is forward-looking so the OS CSPRNG entropy
  -- source is in place when Windows support is completed. bridge_entropy.c uses
  -- only <bcrypt.h> on Windows (no pthread/fork), linked via -lbcrypt.
  if os(windows)
    c-sources:
      csrc/entropy/bridge_entropy.c
    include-dirs:
      csrc
      csrc/entropy
    cc-options: -std=c11 -D_FORTIFY_SOURCE=2 -Wformat -Wformat-security
      -Wno-unused-function -Wno-unused-parameter
    extra-libraries: bcrypt
  if flag(pure-haskell-crypto)
    cpp-options: -DPURE_HASKELL_CRYPTO
  if flag(chaste-build)
    cpp-options: -DCHASTE_BUILD
  if flag(wasm)
    cpp-options: -DWASM_BUILD

executable umbravox
  import:           warnings, lang
  main-is:          Main.hs
  hs-source-dirs:   app/umbravox
  build-depends:
    base         >= 4.18  && < 5,
    UmbraVox
  if !os(windows)
    build-depends:
      unix         >= 2.8   && < 2.11
  ghc-options:      -threaded -rtsopts "-with-rtsopts=-N"

executable umbravox-headless
  import:           warnings, lang
  main-is:          Headless.hs
  hs-source-dirs:   app/umbravox
  build-depends:
    base         >= 4.18  && < 5,
    UmbraVox
  ghc-options:      -threaded -rtsopts "-with-rtsopts=-N"

