# UmbraVOX remote Nix builder defaults.
# This file is intentionally committed so teams can share baseline settings.
# Environment variables always override values from this file.
#
# Required (must be set to a valid builder entry):
#   Format: "<uri> <system> <ssh-key-or-> <max-jobs>"
#   Example:
#     ssh-ng://nixbuilder@builder.example.internal x86_64-linux - 8
UMBRAVOX_NIX_BUILDER=""

# Optional: whether builders may use substituters (true/false, 1/0, yes/no).
UMBRAVOX_NIX_BUILDERS_USE_SUBSTITUTES="true"

# Fail-closed policy: must remain enabled.
# Local fallback is intentionally disabled for VM image builds.
UMBRAVOX_NIX_REMOTE_REQUIRED="1"
