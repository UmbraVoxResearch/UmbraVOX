# UmbraVOX VM-local Nix build defaults
# ------------------------------------
# This file is committed and provides repository defaults.
# You can override any value with environment variables.
#
# Override examples:
#   export UMBRAVOX_NIX_BUILD_DIR="build/vm/tmp"
#   export UMBRAVOX_NIX_SANDBOX_BUILD_DIR="/build"
#   export UMBRAVOX_NIX_LOCAL_ONLY=1
#   make vm-image-build
#
# Fail-closed:
#   - UMBRAVOX_NIX_LOCAL_ONLY must remain 1.
#   - Remote-builder variables are rejected by scripts/nix-vm-build-config.sh.

UMBRAVOX_NIX_BUILD_DIR=build/vm/tmp
UMBRAVOX_NIX_SANDBOX_BUILD_DIR=/build
UMBRAVOX_NIX_LOCAL_ONLY=1
UMBRAVOX_NIX_REQUIRE_CONFIG=1
