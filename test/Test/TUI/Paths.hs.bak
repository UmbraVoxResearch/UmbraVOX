------------------------------------------------------------------------
-- DlgNewConn submenu
------------------------------------------------------------------------

testNewConn1CreatesSecureNotes :: IO Bool
testNewConn1CreatesSecureNotes = do
    st <- mkTestState
    writeIORef (asDialogMode st) (Just DlgNewConn)
    handleNewConnDlg st (KeyChar '1')
    -- After '1', dialog should be closed and a session should exist
    dlg <- readIORef (asDialogMode st)
    sessions <- readIORef (cfgSessions (asConfig st))
    a <- assertEq "newConn '1' closes dialog" True (isDlgNothing dlg)
    b <- assertEq "newConn '1' creates session" True (Map.size sessions > 0)
    pure (a && b)

testNewConnUnknownCloses :: IO Bool
testNewConnUnknownCloses = do
    st <- mkTestState
    writeIORef (asDialogMode st) (Just DlgNewConn)
    handleNewConnDlg st (KeyChar 'z')
    dlg <- readIORef (asDialogMode st)
    assertEq "newConn unknown key closes dialog" True (isDlgNothing dlg)

------------------------------------------------------------------------
-- DlgPrompt
------------------------------------------------------------------------

testPromptKeyCharAppends :: IO Bool
testPromptKeyCharAppends = do
    st <- mkTestState
    writeIORef (asDialogBuf st) "hel"
    writeIORef (asDialogMode st) (Just (DlgPrompt "test" (\_ -> pure ())))
    handleDialog st (KeyChar 'l')
    buf <- readIORef (asDialogBuf st)
    assertEq "prompt KeyChar appends to dialogBuf" "hell" buf

testPromptKeyBackspaceRemoves :: IO Bool
testPromptKeyBackspaceRemoves = do
    st <- mkTestState
    writeIORef (asDialogBuf st) "hello"
    writeIORef (asDialogMode st) (Just (DlgPrompt "test" (\_ -> pure ())))
    handleDialog st KeyBackspace
    buf <- readIORef (asDialogBuf st)
    assertEq "prompt KeyBackspace removes from dialogBuf" "hell" buf

testPromptKeyBackspaceEmptyStaysEmpty :: IO Bool
testPromptKeyBackspaceEmptyStaysEmpty = do
    st <- mkTestState
    writeIORef (asDialogBuf st) ""
    writeIORef (asDialogMode st) (Just (DlgPrompt "test" (\_ -> pure ())))
    handleDialog st KeyBackspace
    buf <- readIORef (asDialogBuf st)
    assertEq "prompt KeyBackspace empty stays empty" "" buf

testPromptKeyEnterTriggersCallback :: IO Bool
testPromptKeyEnterTriggersCallback = do
    st <- mkTestState
    callbackRef <- newIORef ""
    writeIORef (asDialogBuf st) "myvalue"
    writeIORef (asDialogMode st) (Just (DlgPrompt "test" (\v -> writeIORef callbackRef v)))
    handleDialog st KeyEnter
    val <- readIORef callbackRef
    assertEq "prompt KeyEnter triggers callback with buf" "myvalue" val

testPromptKeyEnterClosesDialog :: IO Bool
testPromptKeyEnterClosesDialog = do
    st <- mkTestState
    writeIORef (asDialogBuf st) "val"
    writeIORef (asDialogMode st) (Just (DlgPrompt "test" (\_ -> pure ())))
    handleDialog st KeyEnter
    dlg <- readIORef (asDialogMode st)
    assertEq "prompt KeyEnter closes dialog" True (isDlgNothing dlg)

testPromptKeyEnterClearsBuf :: IO Bool
testPromptKeyEnterClearsBuf = do
    st <- mkTestState
    writeIORef (asDialogBuf st) "val"
    writeIORef (asDialogMode st) (Just (DlgPrompt "test" (\_ -> pure ())))
    handleDialog st KeyEnter
    buf <- readIORef (asDialogBuf st)
    assertEq "prompt KeyEnter clears dialogBuf" "" buf

