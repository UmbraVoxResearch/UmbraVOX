-- | Comprehensive TUI integration tests: exercises every UI path by creating
-- a mock AppState with IORefs, calling handlers directly, and checking state.
module Test.TUI.Paths (runTests) where

import Data.IORef (newIORef, readIORef, writeIORef, modifyIORef')
import qualified Data.Map.Strict as Map
import Test.Util (assertEq)
import UmbraVox.TUI.Types
import UmbraVox.TUI.Input (handleNormal, handleContact, handleChat,
                           handleDialog,
                           handleSettingsDlg, handleNewConnDlg)
import UmbraVox.TUI.Menu (handleMenu, toggleMenu, openMenu, closeMenu,
                          executeMenuItem)
import UmbraVox.TUI.Render (calcLayout)
import UmbraVox.Chat.Session (initChatSession)
import UmbraVox.Crypto.Random (randomBytes)

------------------------------------------------------------------------
-- Test state construction
------------------------------------------------------------------------

-- | Create a minimal AppState suitable for testing.
-- All IORefs are initialized with sensible defaults.
mkTestState :: IO AppState
mkTestState = do
    cfg <- mkTestConfig
    let lay = calcLayout 40 120
    AppState cfg
        <$> newIORef 0           -- asSelected
        <*> newIORef ContactPane -- asFocus
        <*> newIORef ""          -- asInputBuf
        <*> newIORef ""          -- asDialogBuf
        <*> newIORef 0           -- asChatScroll
        <*> newIORef ""          -- asStatusMsg
        <*> newIORef True        -- asRunning
        <*> newIORef Nothing     -- asDialogMode
        <*> newIORef lay         -- asLayout
        <*> newIORef 0           -- asContactScroll
        <*> newIORef (40, 120)   -- asTermSize
        <*> newIORef Nothing     -- asMenuOpen
        <*> newIORef 0           -- asMenuIndex

mkTestConfig :: IO AppConfig
mkTestConfig =
    AppConfig
        <$> newIORef 1111        -- cfgListenPort
        <*> newIORef "testuser"  -- cfgDisplayName
        <*> newIORef Nothing     -- cfgIdentity
        <*> newIORef Map.empty   -- cfgSessions
        <*> newIORef 1           -- cfgNextId
        <*> newIORef False       -- cfgMDNSEnabled
        <*> newIORef False       -- cfgPEXEnabled
        <*> newIORef False       -- cfgDBEnabled
        <*> newIORef ""          -- cfgDBPath
        <*> newIORef Nothing     -- cfgMDNSThread
        <*> newIORef []          -- cfgMDNSPeers
        <*> newIORef 30          -- cfgRetentionDays
        <*> newIORef False       -- cfgAutoSaveMessages
        <*> newIORef Nothing     -- cfgAnthonyDB
        <*> newIORef False       -- cfgTrustedOnly

-- | Add a loopback session to the test config and return its SessionId.
addTestSession :: AppConfig -> String -> IO SessionId
addTestSession cfg label = do
    sid <- readIORef (cfgNextId cfg)
    writeIORef (cfgNextId cfg) (sid + 1)
    secret <- randomBytes 32
    dhSec <- randomBytes 32
    peerPub <- randomBytes 32
    session <- initChatSession secret dhSec peerPub
    ref <- newIORef session
    histRef <- newIORef []
    stRef <- newIORef Local
    let si = SessionInfo Nothing ref Nothing label histRef stRef
    modifyIORef' (cfgSessions cfg) (Map.insert sid si)
    pure sid

-- | Add a session pre-loaded with mock history messages.
addSessionWithHistory :: AppConfig -> String -> [String] -> IO SessionId
addSessionWithHistory cfg label msgs = do
    sid <- readIORef (cfgNextId cfg)
    writeIORef (cfgNextId cfg) (sid + 1)
    secret <- randomBytes 32
    dhSec <- randomBytes 32
    peerPub <- randomBytes 32
    session <- initChatSession secret dhSec peerPub
    ref <- newIORef session
    histRef <- newIORef msgs
    stRef <- newIORef Local
    let si = SessionInfo Nothing ref Nothing label histRef stRef
    modifyIORef' (cfgSessions cfg) (Map.insert sid si)
    pure sid

------------------------------------------------------------------------
-- Runner
------------------------------------------------------------------------

runTests :: IO Bool
runTests = do
    putStrLn "Test.TUI.Paths"
    putStrLn (replicate 40 '-')
    results <- sequence
        -- Contact Pane navigation
        [ testContactKeyUpClampsAtZero
        , testContactKeyUpDecrements
        , testContactKeyDownIncrements
        , testContactKeyDownClampsAtMax
        , testContactKeyEnterSwitchesToChat
        , testContactKeyEnterResetsScroll
        , testContactKeyTabToggles

        -- Chat Pane input
        , testChatKeyCharAppends
        , testChatKeyCharMultiple
        , testChatKeyBackspaceRemoves
        , testChatKeyBackspaceEmptyStaysEmpty
        , testChatKeyUpScrollsUp
        , testChatKeyDownScrollsDown
        , testChatKeyDownScrollClampsAtZero
        , testChatPageUpScrollsByPage
        , testChatPageDownScrollsByPage
        , testChatPageDownClampsAtZero

        -- Chat simulation tests
        , testChatInputAccumulates
        , testChatInputMaxLength
        , testChatBackspaceEmpty
        , testChatBackspaceRemoves
        , testChatScrollUpIncrement
        , testChatScrollDownAtZero
        , testChatPageUpIncrement
        , testChatPageDownClampZero

        -- Dialog opening
        , testCtrlNOpensDlgNewConn

        -- Dialog closing
        , testEscapeClosesDialog
        , testEscapeClosesDlgHelp
        , testEscapeClosesDlgSettings
        , testEscapeClosesDlgNewConn
        , testAnyKeyClosesDlgHelp
        , testAnyKeyClosesDlgKeys
        , testAnyKeyClosesDlgVerify

        -- DlgSettings submenu
        , testSettings1OpensPortPrompt
        , testSettings2OpensNamePrompt
        , testSettings3TogglesMDNS
        , testSettings4TogglesPEX
        , testSettings5TogglesDB
        , testSettings8TogglesAutoSave
        , testSettings0OpensDlgKeys
        , testSettingsUnknownCloses

        -- Settings dialog simulation tests
        , testSettingsPortPrompt
        , testSettingsNamePrompt
        , testSettingsMDNSToggle
        , testSettingsMDNSToggleBack
        , testSettingsPEXToggle
        , testSettingsDBToggle
        , testSettingsAutoSaveToggle
        , testSettingsKeysOpens
        , testSettingsUnknownCloses'

        -- DlgNewConn submenu
        , testNewConn1CreatesSecureNotes
        , testNewConnUnknownCloses

        -- DlgPrompt
        , testPromptKeyCharAppends
        , testPromptKeyBackspaceRemoves
        , testPromptKeyBackspaceEmptyStaysEmpty
        , testPromptKeyEnterTriggersCallback
        , testPromptKeyEnterClosesDialog
        , testPromptKeyEnterClearsBuf

        -- Global quit
        , testCtrlQSetsRunningFalse
        , testCtrlDSetsRunningFalse

        -- Tab toggle roundtrip
        , testTabToggleRoundtrip

        -- Menu open/close
        , testF1OpensFileMenu
        , testF2OpensContactsMenu
        , testF3OpensChatMenu
        , testF4OpensPrefsMenu
        , testF5OpensHelpMenu
        , testMenuEscCloses
        , testMenuToggleSameCloses
        , testMenuLeftRight
        , testMenuDownIncrementsIndex
        , testMenuUpDecrementsIndex

        -- Menu item execution
        , testMenuFileExport
        , testMenuFileImport
        , testMenuFileQuit
        , testMenuContactsNew
        , testMenuContactsRename
        , testMenuContactsBrowse
        , testMenuContactsVerify
        , testMenuChatClearInput
        , testMenuPrefsSettings
        , testMenuPrefsKeys
        , testMenuPrefsMDNS
        , testMenuHelpHelp

        -- Workflow: complete user workflows (multi-keystroke sequences)
        , testWorkflowCreateSecureNotes
        , testWorkflowTypeAndClear
        , testWorkflowOpenCloseMultipleMenus
        , testWorkflowSettingsToggleMDNS
        , testWorkflowNavigateContacts
        , testWorkflowChatScroll
        , testWorkflowEscapeFromNested
        ]
    pure (and results)

------------------------------------------------------------------------
-- Contact Pane navigation
------------------------------------------------------------------------

testContactKeyUpClampsAtZero :: IO Bool
testContactKeyUpClampsAtZero = do
    st <- mkTestState
    _ <- addTestSession (asConfig st) "Alice"
    writeIORef (asSelected st) 0
    handleContact st KeyUp
    sel <- readIORef (asSelected st)
    assertEq "contact KeyUp clamps at 0" 0 sel

testContactKeyUpDecrements :: IO Bool
testContactKeyUpDecrements = do
    st <- mkTestState
    _ <- addTestSession (asConfig st) "Alice"
    _ <- addTestSession (asConfig st) "Bob"
    _ <- addTestSession (asConfig st) "Carol"
    writeIORef (asSelected st) 2
    handleContact st KeyUp
    sel <- readIORef (asSelected st)
    assertEq "contact KeyUp decrements" 1 sel

testContactKeyDownIncrements :: IO Bool
testContactKeyDownIncrements = do
    st <- mkTestState
    _ <- addTestSession (asConfig st) "Alice"
    _ <- addTestSession (asConfig st) "Bob"
    _ <- addTestSession (asConfig st) "Carol"
    writeIORef (asSelected st) 0
    handleContact st KeyDown
    sel <- readIORef (asSelected st)
    assertEq "contact KeyDown increments" 1 sel

testContactKeyDownClampsAtMax :: IO Bool
testContactKeyDownClampsAtMax = do
    st <- mkTestState
    _ <- addTestSession (asConfig st) "Alice"
    _ <- addTestSession (asConfig st) "Bob"
    writeIORef (asSelected st) 1
    handleContact st KeyDown
    sel <- readIORef (asSelected st)
    assertEq "contact KeyDown clamps at n-1" 1 sel

testContactKeyEnterSwitchesToChat :: IO Bool
testContactKeyEnterSwitchesToChat = do
    st <- mkTestState
    _ <- addTestSession (asConfig st) "Alice"
    writeIORef (asFocus st) ContactPane
    handleContact st KeyEnter
    focus <- readIORef (asFocus st)
    assertEq "contact KeyEnter switches to ChatPane" True (focus == ChatPane)

testContactKeyEnterResetsScroll :: IO Bool
testContactKeyEnterResetsScroll = do
    st <- mkTestState
    _ <- addTestSession (asConfig st) "Alice"
    writeIORef (asChatScroll st) 5
    handleContact st KeyEnter
    scroll <- readIORef (asChatScroll st)
    assertEq "contact KeyEnter resets scroll to 0" 0 scroll

testContactKeyTabToggles :: IO Bool
testContactKeyTabToggles = do
    st <- mkTestState
    writeIORef (asFocus st) ContactPane
    handleNormal st KeyTab
    focus <- readIORef (asFocus st)
    assertEq "KeyTab toggles ContactPane->ChatPane" True (focus == ChatPane)

------------------------------------------------------------------------
-- Chat Pane input
