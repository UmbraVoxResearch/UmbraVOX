testChatKeyCharAppends :: IO Bool
testChatKeyCharAppends = do
    st <- mkTestState
    writeIORef (asInputBuf st) "hel"
    handleChat st (KeyChar 'l')
    buf <- readIORef (asInputBuf st)
    assertEq "chat KeyChar appends" "hell" buf

testChatKeyCharMultiple :: IO Bool
testChatKeyCharMultiple = do
    st <- mkTestState
    writeIORef (asInputBuf st) ""
    handleChat st (KeyChar 'h')
    handleChat st (KeyChar 'i')
    buf <- readIORef (asInputBuf st)
    assertEq "chat KeyChar multiple appends" "hi" buf

testChatKeyBackspaceRemoves :: IO Bool
testChatKeyBackspaceRemoves = do
    st <- mkTestState
    writeIORef (asInputBuf st) "hello"
    handleChat st KeyBackspace
    buf <- readIORef (asInputBuf st)
    assertEq "chat KeyBackspace removes last" "hell" buf

testChatKeyBackspaceEmptyStaysEmpty :: IO Bool
testChatKeyBackspaceEmptyStaysEmpty = do
    st <- mkTestState
    writeIORef (asInputBuf st) ""
    handleChat st KeyBackspace
    buf <- readIORef (asInputBuf st)
    assertEq "chat KeyBackspace empty stays empty" "" buf

testChatKeyUpScrollsUp :: IO Bool
testChatKeyUpScrollsUp = do
    st <- mkTestState
    writeIORef (asChatScroll st) 3
    handleChat st KeyUp
    scroll <- readIORef (asChatScroll st)
    assertEq "chat KeyUp increments scroll" 4 scroll

testChatKeyDownScrollsDown :: IO Bool
testChatKeyDownScrollsDown = do
    st <- mkTestState
    writeIORef (asChatScroll st) 5
    handleChat st KeyDown
    scroll <- readIORef (asChatScroll st)
    assertEq "chat KeyDown decrements scroll" 4 scroll

testChatKeyDownScrollClampsAtZero :: IO Bool
testChatKeyDownScrollClampsAtZero = do
    st <- mkTestState
    writeIORef (asChatScroll st) 0
    handleChat st KeyDown
    scroll <- readIORef (asChatScroll st)
    assertEq "chat KeyDown clamps at 0" 0 scroll

testChatPageUpScrollsByPage :: IO Bool
testChatPageUpScrollsByPage = do
    st <- mkTestState
    lay <- readIORef (asLayout st)
    let ch = lChatH lay
    writeIORef (asChatScroll st) 0
    handleChat st KeyPageUp
    scroll <- readIORef (asChatScroll st)
    assertEq "chat PageUp scrolls by chatH" ch scroll

testChatPageDownScrollsByPage :: IO Bool
testChatPageDownScrollsByPage = do
    st <- mkTestState
    lay <- readIORef (asLayout st)
    let ch = lChatH lay
    writeIORef (asChatScroll st) (ch * 2)
    handleChat st KeyPageDown
    scroll <- readIORef (asChatScroll st)
    assertEq "chat PageDown scrolls by chatH" ch scroll

testChatPageDownClampsAtZero :: IO Bool
testChatPageDownClampsAtZero = do
    st <- mkTestState
    writeIORef (asChatScroll st) 2
    handleChat st KeyPageDown
    scroll <- readIORef (asChatScroll st)
    assertEq "chat PageDown clamps at 0" 0 scroll

------------------------------------------------------------------------
-- Chat simulation tests
------------------------------------------------------------------------

testChatInputAccumulates :: IO Bool
testChatInputAccumulates = do
    st <- mkTestState
    writeIORef (asInputBuf st) ""
    handleChat st (KeyChar 'h')
    handleChat st (KeyChar 'e')
    handleChat st (KeyChar 'l')
    handleChat st (KeyChar 'l')
    handleChat st (KeyChar 'o')
    buf <- readIORef (asInputBuf st)
    assertEq "chat input accumulates 'hello'" "hello" buf

testChatInputMaxLength :: IO Bool
testChatInputMaxLength = do
    st <- mkTestState
    writeIORef (asInputBuf st) (replicate 4096 'x')
    handleChat st (KeyChar 'y')
    buf <- readIORef (asInputBuf st)
    assertEq "chat input max length stays 4096" 4096 (length buf)

testChatBackspaceEmpty :: IO Bool
testChatBackspaceEmpty = do
    st <- mkTestState
    writeIORef (asInputBuf st) ""
    handleChat st KeyBackspace
    buf <- readIORef (asInputBuf st)
    assertEq "chat backspace on empty stays empty" "" buf

testChatBackspaceRemoves :: IO Bool
testChatBackspaceRemoves = do
    st <- mkTestState
    writeIORef (asInputBuf st) "abc"
    handleChat st KeyBackspace
    buf <- readIORef (asInputBuf st)
    assertEq "chat backspace 'abc' -> 'ab'" "ab" buf

testChatScrollUpIncrement :: IO Bool
testChatScrollUpIncrement = do
    st <- mkTestState
    writeIORef (asChatScroll st) 0
    handleChat st KeyUp
    scroll <- readIORef (asChatScroll st)
    assertEq "chat KeyUp increments scroll by 1" 1 scroll

testChatScrollDownAtZero :: IO Bool
testChatScrollDownAtZero = do
    st <- mkTestState
    writeIORef (asChatScroll st) 0
    handleChat st KeyDown
    scroll <- readIORef (asChatScroll st)
    assertEq "chat KeyDown at 0 stays 0" 0 scroll

testChatPageUpIncrement :: IO Bool
testChatPageUpIncrement = do
    st <- mkTestState
    lay <- readIORef (asLayout st)
    let ch = lChatH lay
    writeIORef (asChatScroll st) 0
    handleChat st KeyPageUp
    scroll <- readIORef (asChatScroll st)
    assertEq "chat PageUp increments by lChatH" ch scroll

testChatPageDownClampZero :: IO Bool
testChatPageDownClampZero = do
    st <- mkTestState
    lay <- readIORef (asLayout st)
    let _ch = lChatH lay
    writeIORef (asChatScroll st) 3
    handleChat st KeyPageDown
    scroll <- readIORef (asChatScroll st)
    assertEq "chat PageDown clamps to 0 when scroll < page" 0 scroll

