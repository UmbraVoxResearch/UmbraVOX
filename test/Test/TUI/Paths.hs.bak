------------------------------------------------------------------------
-- Workflow tests: complete multi-keystroke user workflows
------------------------------------------------------------------------

-- | Workflow 1: F2 (open contacts menu) -> Enter (select "New" at index 0)
--   -> handleNewConnDlg '1' -> verify session created + dialog closed
testWorkflowCreateSecureNotes :: IO Bool
testWorkflowCreateSecureNotes = do
    st <- mkTestState
    -- Step 1: F2 opens the Contacts menu
    handleNormal st KeyF2
    m1 <- readIORef (asMenuOpen st)
    a <- assertEq "wf1: F2 opens MenuContacts" True (m1 == Just MenuContacts)
    -- Step 2: Down to index 0 is already "New" (openMenu resets to 0),
    -- navigate Down for the spec, then back up to stay at "New"
    handleMenu st KeyDown     -- index 0 -> 1
    handleMenu st KeyUp       -- index 1 -> 0
    -- Step 3: Enter selects "New" -> activateMenuItem -> startNewConn -> DlgNewConn
    handleMenu st KeyEnter
    dlg1 <- readIORef (asDialogMode st)
    b <- assertEq "wf1: menu enter opens DlgNewConn" True (isDlgNewConn dlg1)
    -- Step 4: In DlgNewConn, press '1' for Secure Notes
    handleNewConnDlg st (KeyChar '1')
    dlg2 <- readIORef (asDialogMode st)
    sessions <- readIORef (cfgSessions (asConfig st))
    c <- assertEq "wf1: dialog closed after secure notes" True (isDlgNothing dlg2)
    d <- assertEq "wf1: session created" True (Map.size sessions > 0)
    pure (and [a,b,c,d])

-- | Workflow 2: Tab to ChatPane -> type "hello world" -> F3 (chat menu)
--   -> Down -> Enter (select "Clear Input") -> verify asInputBuf = ""
testWorkflowTypeAndClear :: IO Bool
testWorkflowTypeAndClear = do
    st <- mkTestState
    -- Step 1: Tab to ChatPane
    writeIORef (asFocus st) ContactPane
    handleNormal st KeyTab
    -- Step 2: Type "hello world"
    mapM_ (\c -> handleChat st (KeyChar c)) "hello world"
    buf1 <- readIORef (asInputBuf st)
    a <- assertEq "wf2: typed 'hello world'" "hello world" buf1
    -- Step 3: F3 opens chat menu
    handleNormal st KeyF3
    -- Step 4: Down once to move from index 0 ("Send") to index 1 ("Clear Input")
    handleMenu st KeyDown
    idx <- readIORef (asMenuIndex st)
    b <- assertEq "wf2: menu index at 1" 1 idx
    -- Step 5: Enter selects "Clear Input"
    handleMenu st KeyEnter
    buf2 <- readIORef (asInputBuf st)
    c <- assertEq "wf2: input cleared" "" buf2
    pure (a && b && c)

-- | Workflow 3: F1 -> Esc -> F2 -> Esc -> F5 -> Esc -> verify all closed
testWorkflowOpenCloseMultipleMenus :: IO Bool
testWorkflowOpenCloseMultipleMenus = do
    st <- mkTestState
    -- F1 -> Esc
    handleNormal st KeyF1
    m1 <- readIORef (asMenuOpen st)
    a <- assertEq "wf3: F1 opens MenuFile" True (m1 == Just MenuFile)
    handleMenu st KeyEscape
    m2 <- readIORef (asMenuOpen st)
    b <- assertEq "wf3: Esc closes MenuFile" True (m2 == Nothing)
    -- F2 -> Esc
    handleNormal st KeyF2
    m3 <- readIORef (asMenuOpen st)
    c <- assertEq "wf3: F2 opens MenuContacts" True (m3 == Just MenuContacts)
    handleMenu st KeyEscape
    m4 <- readIORef (asMenuOpen st)
    d <- assertEq "wf3: Esc closes MenuContacts" True (m4 == Nothing)
    -- F5 -> Esc
    handleNormal st KeyF5
    m5 <- readIORef (asMenuOpen st)
    e <- assertEq "wf3: F5 opens MenuHelp" True (m5 == Just MenuHelp)
    handleMenu st KeyEscape
    m6 <- readIORef (asMenuOpen st)
    f <- assertEq "wf3: Esc closes MenuHelp" True (m6 == Nothing)
    pure (and [a,b,c,d,e,f])

-- | Workflow 4: F4 -> Down -> Down -> Enter (select "mDNS Toggle")
--   -> verify cfgMDNSEnabled changed
testWorkflowSettingsToggleMDNS :: IO Bool
testWorkflowSettingsToggleMDNS = do
    st <- mkTestState
    before <- readIORef (cfgMDNSEnabled (asConfig st))
    -- Step 1: F4 opens Prefs menu
    handleNormal st KeyF4
    -- Step 2: Down twice to reach index 2 ("mDNS Toggle")
    -- MenuPrefs items: [0] Settings, [1] Keys, [2] mDNS Toggle
    handleMenu st KeyDown   -- index 0 -> 1
    handleMenu st KeyDown   -- index 1 -> 2
    idx <- readIORef (asMenuIndex st)
    a <- assertEq "wf4: menu index at 2" 2 idx
    -- Step 3: Enter activates mDNS Toggle
    handleMenu st KeyEnter
    after <- readIORef (cfgMDNSEnabled (asConfig st))
    b <- assertEq "wf4: mDNS toggled" (not before) after
    -- Menu should be closed after activation
    m <- readIORef (asMenuOpen st)
    c <- assertEq "wf4: menu closed after activate" True (m == Nothing)
    pure (a && b && c)

-- | Workflow 5: Add 5 sessions -> KeyDown 3 times -> KeyEnter
--   -> verify selected=3, focus=ChatPane
testWorkflowNavigateContacts :: IO Bool
testWorkflowNavigateContacts = do
    st <- mkTestState
    -- Add 5 sessions
    _ <- addTestSession (asConfig st) "Alice"
    _ <- addTestSession (asConfig st) "Bob"
    _ <- addTestSession (asConfig st) "Carol"
    _ <- addTestSession (asConfig st) "Dave"
    _ <- addTestSession (asConfig st) "Eve"
    -- Start at ContactPane, selected=0
    writeIORef (asFocus st) ContactPane
    writeIORef (asSelected st) 0
    -- KeyDown 3 times
    handleContact st KeyDown   -- 0 -> 1
    handleContact st KeyDown   -- 1 -> 2
    handleContact st KeyDown   -- 2 -> 3
    sel <- readIORef (asSelected st)
    a <- assertEq "wf5: selected=3 after 3 downs" 3 sel
    -- KeyEnter switches to ChatPane
    handleContact st KeyEnter
    focus <- readIORef (asFocus st)
    b <- assertEq "wf5: focus=ChatPane after enter" True (focus == ChatPane)
    pure (a && b)

-- | Workflow 6: Add a session with 20 history messages -> Tab to ChatPane
--   -> PageUp -> verify asChatScroll > 0 -> PageDown -> verify scroll decreased
testWorkflowChatScroll :: IO Bool
testWorkflowChatScroll = do
    st <- mkTestState
    let msgs = map (\i -> "[00:00] Peer: message " ++ show i) [1..20 :: Int]
    _ <- addSessionWithHistory (asConfig st) "HistoryPeer" msgs
    -- Tab to ChatPane
    writeIORef (asFocus st) ContactPane
    handleNormal st KeyTab
    -- Verify we are in ChatPane
    focus <- readIORef (asFocus st)
    a <- assertEq "wf6: focus=ChatPane" True (focus == ChatPane)
    -- PageUp
    handleChat st KeyPageUp
    scroll1 <- readIORef (asChatScroll st)
    b <- assertEq "wf6: scroll > 0 after PageUp" True (scroll1 > 0)
    -- PageDown
    handleChat st KeyPageDown
    scroll2 <- readIORef (asChatScroll st)
    c <- assertEq "wf6: scroll decreased after PageDown" True (scroll2 < scroll1)
    pure (a && b && c)

-- | Workflow 7: Open DlgSettings -> press '1' (opens DlgPrompt)
--   -> Esc -> verify back to Nothing (not back to DlgSettings)
testWorkflowEscapeFromNested :: IO Bool
testWorkflowEscapeFromNested = do
    st <- mkTestState
    -- Step 1: Open DlgSettings
    writeIORef (asDialogMode st) (Just DlgSettings)
    dlg1 <- readIORef (asDialogMode st)
    a <- assertEq "wf7: DlgSettings open" True (isDlgSettings dlg1)
    -- Step 2: Press '1' which opens DlgPrompt (port prompt)
    handleSettingsDlg st (KeyChar '1')
    dlg2 <- readIORef (asDialogMode st)
    b <- assertEq "wf7: DlgPrompt open after '1'" True (isDlgPrompt dlg2)
    -- Step 3: Escape closes the prompt entirely (goes to Nothing, not DlgSettings)
    handleDialog st KeyEscape
    dlg3 <- readIORef (asDialogMode st)
    c <- assertEq "wf7: dialog is Nothing after Esc" True (isDlgNothing dlg3)
    pure (a && b && c)

------------------------------------------------------------------------
-- Dialog mode helpers (DialogMode has no Eq instance)
------------------------------------------------------------------------

isDlgNewConn :: Maybe DialogMode -> Bool
isDlgNewConn (Just DlgNewConn) = True
isDlgNewConn _ = False

isDlgSettings :: Maybe DialogMode -> Bool
isDlgSettings (Just DlgSettings) = True
isDlgSettings _ = False

isDlgHelp :: Maybe DialogMode -> Bool
isDlgHelp (Just DlgHelp) = True
isDlgHelp _ = False

isDlgKeys :: Maybe DialogMode -> Bool
isDlgKeys (Just DlgKeys) = True
isDlgKeys _ = False

isDlgBrowse :: Maybe DialogMode -> Bool
isDlgBrowse (Just DlgBrowse) = True
isDlgBrowse _ = False

isDlgVerify :: Maybe DialogMode -> Bool
isDlgVerify (Just DlgVerify) = True
isDlgVerify _ = False

isDlgPrompt :: Maybe DialogMode -> Bool
isDlgPrompt (Just (DlgPrompt _ _)) = True
isDlgPrompt _ = False

isDlgNothing :: Maybe DialogMode -> Bool
isDlgNothing Nothing = True
isDlgNothing _ = False
